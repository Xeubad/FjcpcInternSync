APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173
# 旧版 /api/config 对外展示的基址；留空则用请求自动推导
PUBLIC_BASE_URL=

# 管理台登录（生产务必修改）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
USER_USERNAME=user
USER_PASSWORD=user123

# 数据目录（相对于 backend 工作目录）
DATA_DIR=data

# FJCPC 实习接口（自 app_excel CONFIG 迁移）
FJCPC_API_URL=https://dgsxapi.fjcpc.edu.cn/Reports/StudentOperator
FJCPC_API_HOST=dgsxapi.fjcpc.edu.cn
# Cookie 头模板，{token} 替换为表单/任务里的 fjcpc_token（平台 token）
FJCPC_API_COOKIE_TEMPLATE=PHPSESSID=xxx; fjczqxy_session=xxx; token={token}
FJCPC_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/141.0.0.0 Safari/537.36
FJCPC_REFERER=https://dgsx.fjcpc.edu.cn/
FJCPC_ORIGIN=https://dgsx.fjcpc.edu.cn/
FJCPC_REQUEST_INTERVAL=2
FJCPC_REQUEST_TIMEOUT=10
# cookie_first | token_first
FJCPC_AUTH_PRIORITY=cookie_first
FJCPC_VERIFY_TLS=false
# 留空则使用 data/config/browser_cookies.json；若需外置文件请写绝对路径或相对「启动时当前工作目录」的路径
FJCPC_BROWSER_COOKIES_PATH=
# 留空则与读取路径一致，否则单独指定保存路径
FJCPC_BROWSER_COOKIES_WRITE_PATH=

# 旧版一次性访问令牌（留空则使用 DATA_DIR/config/access_tokens.json）
ACCESS_TOKENS_FILE=
ADMIN_KEY=fjcpc2025
DEV_ACCESS_TOKEN=123
TOKEN_EXPIRE_DAYS=7
# 为 true 时即使有学号+token 也不发真实 HTTP（联调用）
FJCPC_DRY_RUN=false

# 兼容旧占位（上传已走 FJCPC_*，此项可留空）
UPSTREAM_BASE_URL=
UPSTREAM_VERIFY_TLS=false

DB_ENABLED=false
QUEUE_ENABLED=false

# React 打包目录；留空则使用项目根下 frontend/dist（后端托管 SPA）
SPA_STATIC_DIR=
