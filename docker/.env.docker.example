# FjcpcInternSync 容器运行时环境变量模板
# 用法：cp .env.docker.example .env.docker 后按需修改，再 docker compose up -d
# 仅列出容器部署常用项；完整变量说明见 backend/.env.example。

APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# 后端与 SPA 同源（同一容器同端口），CORS 可留空
CORS_ORIGINS=

# 管理台登录账号 —— 生产务必修改
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin
USER_USERNAME=user
USER_PASSWORD=change-me-user

# 管理员密钥 —— 生产务必修改
ADMIN_KEY=change-me-key

# FJCPC 实习平台上游接口
FJCPC_API_URL=https://dgsxapi.fjcpc.edu.cn/Reports/StudentOperator
FJCPC_API_HOST=dgsxapi.fjcpc.edu.cn
# Cookie 头模板，{token} 会被平台 token 替换；占位 xxx 需替换为真实会话值
FJCPC_API_COOKIE_TEMPLATE=PHPSESSID=xxx; fjczqxy_session=xxx; token={token}
FJCPC_REFERER=https://dgsx.fjcpc.edu.cn/
FJCPC_ORIGIN=https://dgsx.fjcpc.edu.cn/
FJCPC_AUTH_PRIORITY=cookie_first
FJCPC_VERIFY_TLS=false
FJCPC_REQUEST_INTERVAL=2
FJCPC_REQUEST_TIMEOUT=10
# 联调时设 true 可不发真实请求到实习平台
FJCPC_DRY_RUN=false

# 数据目录：保持默认即可（容器内 /app/backend/data 已挂卷持久化）
DATA_DIR=data

# 浏览器 Cookie 文件留空 -> 回退到 data/config/browser_cookies.json（已挂卷）
FJCPC_BROWSER_COOKIES_PATH=
FJCPC_BROWSER_COOKIES_WRITE_PATH=

# uvicorn 进程数：保持 1。任务在进程内执行，多 worker 会导致
# 内存会话与任务状态不共享，需先接入外部存储才能 >1。
UVICORN_WORKERS=1
